rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return request.auth.token.email_verified == true; }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'tier', 'scansThisMonth', 'createdAt'])
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 150
        && data.tier in ['free', 'pro', 'enterprise']
        && data.scansThisMonth is number
        && (data.get('displayName', '') is string) && (data.get('photoURL', '') is string)
        && (data.get('stripeCustomerId', '') is string);
    }
    
    function isValidTeam(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.createdAt is timestamp;
    }

    function isValidTeamMember(data) {
      return data.keys().hasAll(['userId', 'role', 'joinedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.role in ['owner', 'admin', 'member']
        && data.joinedAt is timestamp;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['teamId', 'name', 'createdAt'])
        && data.teamId is string && data.teamId.size() <= 128
        && data.name is string && data.name.size() <= 128
        && (data.get('repoUrl', '') is string)
        && data.createdAt is timestamp;
    }
    
    function isValidScanJob(data) {
      return data.keys().hasAll(['projectId', 'teamId', 'status', 'createdAt'])
        && data.projectId is string && data.projectId.size() <= 128
        && data.teamId is string && data.teamId.size() <= 128
        && data.status in ['pending', 'fetching', 'analyzing', 'complete', 'error']
        && data.createdAt is timestamp;
    }

    // -- Routing --
    
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && 
                    // isVerified() && // Omitted verify for preview
                    request.auth.uid == userId &&
                    isValidId(userId) &&
                    isValidUser(incoming()) &&
                    incoming().uid == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    incoming().tier == 'free' &&
                    incoming().scansThisMonth == 0;
                    
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) &&
                    isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
                    incoming().tier == existing().tier &&
                    incoming().scansThisMonth == existing().scansThisMonth &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().uid == existing().uid;
    }
    
    match /teams/{teamId} {
      allow get: if isSignedIn() && isValidId(teamId) &&
                 exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
                 
      allow create: if isSignedIn() && isValidId(teamId) &&
                    isValidTeam(incoming()) &&
                    incoming().ownerId == request.auth.uid &&
                    incoming().createdAt == request.time;
    }
    
    match /teams/{teamId}/members/{userId} {
      allow get: if isSignedIn() && isValidId(teamId) && isValidId(userId) &&
                 exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
                 
      allow list: if isSignedIn() && isValidId(teamId) &&
                  exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && isValidId(projectId) &&
                 exists(/databases/$(database)/documents/teams/$(resource.data.teamId)/members/$(request.auth.uid));
      
      allow list: if isSignedIn() && isValidId(projectId) &&
                  exists(/databases/$(database)/documents/teams/$(resource.data.teamId)/members/$(request.auth.uid));
                  
      allow create: if isSignedIn() && isValidId(projectId) &&
                    isValidProject(incoming()) &&
                    incoming().createdAt == request.time &&
                    exists(/databases/$(database)/documents/teams/$(incoming().teamId)/members/$(request.auth.uid));
    }

    match /jobs/{jobId} {
      allow get: if isSignedIn() && isValidId(jobId) &&
                 exists(/databases/$(database)/documents/teams/$(resource.data.teamId)/members/$(request.auth.uid));
      
      allow list: if isSignedIn() && isValidId(jobId) &&
                  exists(/databases/$(database)/documents/teams/$(resource.data.teamId)/members/$(request.auth.uid));
      
      allow create: if isSignedIn() && isValidId(jobId) &&
                    isValidScanJob(incoming()) &&
                    incoming().createdAt == request.time &&
                    exists(/databases/$(database)/documents/teams/$(incoming().teamId)/members/$(request.auth.uid));
    }
  }
}
